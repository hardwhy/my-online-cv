{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "admin",
  "projectType": "application",
  "sourceRoot": "apps/admin/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/admin"],
      "options": {
        "command": "tsc -b apps/admin/tsconfig.json && vite build --config apps/admin/vite.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite --config apps/admin/vite.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite preview --config apps/admin/vite.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint apps/admin",
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "tags": ["type:app", "scope:admin"]
}
