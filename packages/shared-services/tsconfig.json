{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "../../dist/packages/shared-services",
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020",
    "tsBuildInfoFile": "../../node_modules/.tmp/packages-shared-services.tsbuildinfo",
    "disableSourceOfProjectReferenceRedirect": true
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../shared-types"
    }
  ]
}
